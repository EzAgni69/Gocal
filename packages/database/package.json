{
    "name": "database",
    "version": "0.0.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "if [ \"$VERCEL\" = \"1\" ]; then npm run db:migrate && npm run db:update-roles; fi && tsc",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:view": "tsx src/view-data.ts",
        "db:update-roles": "tsx src/update_user_role.ts"
    },
    "dependencies": {
        "@neondatabase/serverless": "^0.9.5",
        "@types/ws": "^8.18.1",
        "dotenv": "^16.3.1",
        "drizzle-orm": "^0.38.0",
        "postgres": "^3.4.0",
        "ws": "^8.20.1"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "drizzle-kit": "^0.30.0",
        "tsx": "^4.0.0",
        "typescript": "^5.3.0"
    }
}
